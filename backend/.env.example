# Digital Arrest Interceptor API Settings
PROJECT_NAME="Digital Arrest Interceptor API"

# Database Configuration (Defaults to SQLite in-app database)
DATABASE_URL=sqlite:///./interceptor.db

# LLM Providers Configuration
# If default provider is set to 'fallback', offline rule scoring is active.
# Otherwise, provide API credentials.
DEFAULT_LLM_PROVIDER=fallback
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Score Fusion Weights
# final_score = (RULE_WEIGHT * rule_score) + (LLM_WEIGHT * llm_score)
RULE_WEIGHT=0.4
LLM_WEIGHT=0.6
ALERT_THRESHOLD=75.0
